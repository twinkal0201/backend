<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Note</title>
</head>

<body style="
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
    background:#18181b;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
">

    <div style="
        width:500px;
        background:#27272a;
        padding:20px;
        border-radius:15px;
        color:white;
    ">
        <a href="/" style="
            color:#60a5fa;
            text-decoration:none;
            display:inline-block;
            margin-bottom:20px;
        ">
            ← Go back to Home
        </a>

        <h1><%= filename %></h1>

        <hr style="border-color:#52525b; margin:15px 0;">

        <p style="
            font-size:18px;
            line-height:1.6;
            color:#d4d4d8;
        ">
            <%= filedata %>
        </p>
    </div>

</body>
</html>
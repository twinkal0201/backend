<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Users</title>
</head>

<body style="
    margin:0;
    padding:20px;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
    background:#18181b;
">

    <div style="
        max-width:1200px;
        margin:auto;
    ">
        <h1 style="
            color:white;
            text-align:center;
            margin-bottom:30px;
        ">
            All Users
        </h1>

        <div style="
            display:flex;
            flex-wrap:wrap;
            gap:20px;
            justify-content:center;
        ">

            <% users.forEach(function(user){ %>

                <div style="
                    width:280px;
                    background:#27272a;
                    border-radius:15px;
                    overflow:hidden;
                    box-shadow:0 4px 10px rgba(0,0,0,0.3);
                ">

                    <!-- User Photo -->
                    <img
                        src="<%= user.image %>"
                        alt="Profile"
                        style="
                            width:100%;
                            height:220px;
                            object-fit:cover;
                        "
                    >

                    <!-- User Info -->
                    <div style="padding:18px;">

                        <h2 style="
                            margin:0;
                            color:white;
                            font-size:20px;
                        ">
                            <%= user.name %>
                        </h2>

                        <p style="
                            margin-top:8px;
                            color:#a1a1aa;
                            font-size:15px;
                            word-break:break-word;
                        ">
                            <%= user.email %>
                        </p>

                        <div style="
                            display:flex;
                            justify-content:space-between;
                            margin-top:15px;
                        ">

                            <a
                                href="/user/<%= user.name %>"
                                style="
                                    color:#60a5fa;
                                    text-decoration:none;
                                    font-weight:bold;
                                "
                            >
                                View
                            </a>
                            <a
                                href="/delete/<%= user._id %>"
                                style="
                                    color: red;
                                    text-decoration:none;
                                    font-weight:bold;
                                "
                            >
                                Delete
                            </a>

                            <a
                                href="/edit/<%= user._id %>"
                                style="
                                    color:#22c55e;
                                    text-decoration:none;
                                    font-weight:bold;
                                "
                            >
                                Edit
                            </a>

                        </div>

                    </div>

                </div>

            <% }) %>

        </div>
    </div>

</body>
</html>